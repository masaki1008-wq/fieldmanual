{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "server.js",
      "key.pem",
      "cert.pem",
      "start.bat",
      "start.sh",
      "package.json",
      "package-lock.json",
      "firestore.rules",
      "firestore.indexes.json"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          {"key": "Service-Worker-Allowed", "value": "/"},
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/sw.js",
        "destination": "/sw.js"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "FieldManual",
        "supportEmail": "masakiokuno56@gmail.com",
        "authorizedRedirectUris": [
          "https://fieldmanual-app.web.app",
          "https://fieldmanual-app.firebaseapp.com"
        ]
      }
    }
  },
  "storage": {
    "rules": "storage.rules"
  }
}
